<mujoco model="port_only_scene">
    <compiler angle="degree"/>

    <option timestep="0.002" gravity="0 0 -9.81"/>

    <asset>
        <mesh name="charge_port_mesh" file="assets/Port.obj" scale="0.001 0.001 0.001"/>
    </asset>

    <visual>
        <headlight
            ambient="0.3 0.3 0.3"
            diffuse="0.6 0.6 0.6"
            specular="0.1 0.1 0.1"
        />
    </visual>

    <worldbody>
        <light
            name="main_light"
            pos="0 0 3"
            dir="0 0 -1"
            directional="true"
            diffuse="0.8 0.8 0.8"
            ambient="0.2 0.2 0.2"
        />

        <geom
            name="floor"
            type="plane"
            pos="0 0 0"
            size="3 3 0.1"
            rgba="0.8 0.8 0.8 1"
        />

        <!-- 월드 좌표축 확인용 -->
        <site name="world_origin"
              pos="0 0 0.02"
              size="0.025"
              rgba="1 1 1 1"/>

        <site name="world_x"
              pos="0.3 0 0.02"
              size="0.02"
              rgba="1 0 0 1"/>

        <site name="world_y"
              pos="0 0.3 0.02"
              size="0.02"
              rgba="0 1 0 1"/>

        <site name="world_z"
              pos="0 0 0.3"
              size="0.02"
              rgba="0 0 1 1"/>

        <!-- 충전구 단독 테스트 -->
        <body name="charge_port_frame" pos="0 0 0.5" euler="0 -90 0">
            <geom name="charge_port_visual"
                  type="mesh"
                  mesh="charge_port_mesh"
                  pos="0 0 0"
                  euler="0 0 0"
                  contype="0"
                  conaffinity="0"
                  rgba="0.2 0.2 0.2 1"/>

            <site name="charge_port_center"
                  pos="0 0 0"
                  size="0.025"
                  rgba="0 1 0 1"/>

            <site name="charge_port_axis_site"
                  pos="0 0 -0.10"
                  size="0.02"
                  rgba="1 0 0 1"/>

            <site name="charge_port_approach"
                  pos="0 0 0.15"
                  size="0.025"
                  rgba="1 0.6 0 1"/>

            <site name="charge_port_insert"
                  pos="0 0 -0.02"
                  size="0.02"
                  rgba="0 0 1 1"/>
        </body>

        <camera
            name="overview_camera"
            pos="1.2 -1.5 1.0"
            euler="60 0 40"
            fovy="45"
        />
    </worldbody>
</mujoco>