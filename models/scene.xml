<mujoco model="wemeet_scene">
    <compiler angle="degree"/>

    <option timestep="0.002" gravity="0 0 -9.81"/>

    <include file="robots/ur10e/ur10e.xml"/>
    <asset>
        <mesh name="charge_port_mesh" file="Port.obj" scale="0.001 0.001 0.001"/>
    </asset>
    <visual>
        <headlight
            ambient="0.3 0.3 0.3"
            diffuse="0.6 0.6 0.6"
            specular="0.1 0.1 0.1"
        />
    </visual>

    <worldbody>
        <body name="charge_port" pos="1.0 0.0 0.5" euler="0 -90 0">
            <geom name="charge_port_visual"
                type="mesh"
                mesh="charge_port_mesh"
                contype="0"
                conaffinity="0"
                rgba="0.2 0.2 0.2 1"/>

            <site name="charge_port_center"
                pos="0 0 0"
                size="0.025"
                rgba="0 1 0 1"/>

            <site name="charge_port_axis_site"
                pos="0 0 -0.10"
                size="0.02"
                rgba="1 0 0 1"/>

            <site name="charge_port_approach"
                pos="0 0 0.15"
                euler="180 0 0"
                size="0.025"
                rgba="1 0.6 0 1"/>

            <site name="charge_port_insert"
                pos="0 0 -0.02"
                euler="180 0 0"
                size="0.02"
                rgba="0 0 1 1"/>
        </body>
        <light
            name="main_light"
            pos="0 0 3"
            dir="0 0 -1"
            directional="true"
            diffuse="0.8 0.8 0.8"
            ambient="0.2 0.2 0.2"
        />
        <geom
            name="floor"
            type="plane"
            pos="0 0 0"
            size="5 5 0.1"
            rgba="0.8 0.8 0.8 1"
        />


        <camera
            name="overview_camera"
            pos="2 -3 2"
            euler="60 0 35"
            fovy="45"
        />
    </worldbody>
</mujoco>