<mujoco model="ee_only_scene">
    <compiler angle="degree" meshdir="assets"/>

    <option timestep="0.002" gravity="0 0 -9.81"/>

    <asset>
        <mesh name="ee_mesh" file="EE.obj" scale="0.001 0.001 0.001"/>
    </asset>

    <worldbody>
        <light name="main_light" pos="0 -3 5" dir="0 0 -1"/>

        <geom name="floor"
              type="plane"
              size="5 5 0.1"
              rgba="0.8 0.8 0.8 1"/>

        <body name="ee_body" pos="0 0 0.5">
            <geom name="ee_geom"
                  type="mesh"
                  mesh="ee_mesh"
                  rgba="0.2 0.6 0.9 1"
                  contype="0"
                  conaffinity="0"/>
        </body>

        <camera name="main_camera"
                pos="2 -3 1.5"
                xyaxes="1 0.6 0  -0.2 0.3 1"/>
    </worldbody>
</mujoco>